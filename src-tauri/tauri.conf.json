{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rustory",
  "version": "0.1.0",
  "identifier": "xyz.rustory.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/XurxoMF/rustory/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlEMkU2MEFDNEQwRUQzQjEKUldTeDB3NU5yR0F1bmRPaFljaElVeVZkSm1OU2RlT3lZUVRYcURaL0pISmptdFhyazVnRUtGN3MK",
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "rustory"
        ]
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rustory",
        "width": 1280,
        "height": 720,
        "center": true,
        "minWidth": 1024,
        "minHeight": 600,
        "visible": true,
        "decorations": false,
        "shadow": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": {
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost"
        ]
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": []
        }
      },
      "capabilities": [
        "default",
        "desktop-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "appimage",
      "deb",
      "dmg",
      "nsis",
      "rpm"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}