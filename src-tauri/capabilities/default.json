{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window. Desktop and mobile.",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:app:allow-default-window-icon",
		"core:window:allow-close",
		"core:window:allow-hide",
		"core:window:allow-toggle-maximize",
		"core:window:allow-minimize",
		"core:window:allow-show",
		"core:window:allow-start-dragging",
		"log:default",
		"clipboard-manager:default",
		"notification:default",
		"os:default",
		"shell:default",
		"opener:default",
		"http:default",
		"upload:default",
		"fs:default",
		{
			"identifier": "fs:scope",
			"allow": [
				{ "path": "$APPDATA" },
				{ "path": "$APPDATA/**/*" },
				{ "path": "$APPCONFIG" },
				{ "path": "$APPCONFIG/**/*" },
				{ "path": "$APPCACHE" },
				{ "path": "$APPCACHE/**/*" }
			]
		}
	]
}
