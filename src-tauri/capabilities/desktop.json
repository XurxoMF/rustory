{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "desktop",
	"description": "Capability for the main window. Desktop only.",
	"platforms": ["macOS", "windows", "linux"],
	"windows": ["main"],
	"permissions": [
		"cli:default",
		"updater:default",
		"window-state:default",
		"process:default",
		{ "identifier": "shell:allow-execute", "allow": [{ "name": "check-dotnet", "cmd": "dotnet", "args": true }] }
	]
}
