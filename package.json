{
  "name": "rustory",
  "version": "0.1.0",
  "description": "Launcher for Vintage Story. Everything you need, one click away!",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "paraglide:translate": "inlang machine translate --project rustory.inlang",
    "paraglide:compile": "paraglide-js compile --project ./rustory.inlang --outdir ./src/lib/paraglide",
    "app:update": "bun update && cd src-tauri && cargo update && cd .."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-cli": "~2.4.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-http": "~2.5.9",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-shell": "~2.3.5",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@tauri-apps/plugin-upload": "~2.4.0",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "embla-carousel-autoplay": "^8.6.0",
    "runed": "^0.37.1",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.20.2",
    "@internationalized/date": "^3.12.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tabler/icons-svelte": "^3.44.0",
    "@tanstack/table-core": "^8.21.3",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.13.2",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "embla-carousel-svelte": "^8.6.0",
    "eslint": "^10.6.0",
    "eslint-plugin-svelte": "^3.20.0",
    "formsnap": "^2.0.1",
    "globals": "^17.7.0",
    "layerchart": "2.0.0-next.48",
    "paneforge": "^1.0.2",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "svelte-sonner": "^1.1.1",
    "sveltekit-superforms": "^2.30.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.62.1",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^6.4.3"
  }
}
